<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="AutomationExercise Smoke Suite" parallel="false">
    <listeners>
        <listener class-name="com.automationexercise.listeners.TestListener"/>
    </listeners>
    <parameter name="browser" value="chrome"/>
    <test name="Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.automationexercise.tests.AuthenticationTests"/>
            <class name="com.automationexercise.tests.ProductTests"/>
            <class name="com.automationexercise.tests.CartTests"/>
            <class name="com.automationexercise.tests.ContactAndSubscriptionTests"/>
        </classes>
    </test>
</suite>

